{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./src",
    "paths": {
      "@/*": ["./*"],
      "@config/*": ["./config/*"],
      "@controllers/*": ["./controllers/*"],
      "@routes/*": ["./routes/*"],
      "@middleware/*": ["./middleware/*"],
      "@services/*": ["./services/*"],
      "@database/*": ["./database/*"],
      "@utils/*": ["./utils/*"],
      "@types/*": ["./types/*"],
      "@queues/*": ["./queues/*"],
      "@workers/*": ["./workers/*"],
      "@scrapers/*": ["./scrapers/*"],
      "@intelligence/*": ["./intelligence/*"],
      "@validations/*": ["./validations/*"]
    }
  },
  "include": ["src/**/*"],
  "references": [
    { "path": "../../packages/shared" }
  ]
}
